{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "AuthPilot",
    "version": "0.1.0",
    "identifier": "com.elbssir.authpilot",
    "build": {
        "beforeDevCommand": "pnpm dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "pnpm build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "AuthPilot",
                "width": 1100,
                "height": 720,
                "minWidth": 900,
                "minHeight": 600,
                "decorations": true,
                "resizable": true,
                "center": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "entitlements": "Entitlements.plist",
            "providerShortName": "UD29PDQT67",
            "minimumSystemVersion": "12.0"
        },
        "category": "DeveloperTool",
        "shortDescription": "Multi-provider authentication management tool",
        "longDescription": "AuthPilot is a desktop application for managing authentication across multiple providers including Clerk and AWS Cognito. Validate tokens, manage users, organizations, and sessions from a single interface."
    }
}
